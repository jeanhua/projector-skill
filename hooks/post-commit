#!/bin/bash
# post-commit hook
# 在每次提交后自动检测变更并提示更新 PROJECTOR/ 知识库

set -e

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# 检查 PROJECTOR/ 目录是否存在
if [ ! -d "PROJECTOR" ]; then
    exit 0
fi

# 获取本次提交涉及的文件
CHANGED_FILES=$(git diff-tree --no-commit-id --name-only -r HEAD 2>/dev/null || true)

if [ -z "$CHANGED_FILES" ]; then
    exit 0
fi

# 初始化更新队列
UPDATE_QUEUE_FILE="/tmp/projector-update-queue-$$"
touch "$UPDATE_QUEUE_FILE"

# 分析变更的文件
for file in $CHANGED_FILES; do
    # 跳过 PROJECTOR/ 目录本身的变更
    if [[ "$file" == PROJECTOR/* ]]; then
        continue
    fi

    # 跳过配置文件和文档
    if [[ "$file" == *.md ]] || [[ "$file" == *.txt ]] || [[ "$file" == .gitignore ]]; then
        continue
    fi

    # 提取模块名（第一级目录）
    MODULE=$(echo "$file" | cut -d'/' -f1)

    # 跳过根目录文件
    if [ "$MODULE" = "$file" ]; then
        continue
    fi

    # 检查是否有对应的模块文档
    if [ -f "PROJECTOR/modules/${MODULE}.md" ]; then
        echo "$MODULE" >> "$UPDATE_QUEUE_FILE"
    fi

    # 检查是否是可复用代码
    if [[ "$file" == utils/* ]] || [[ "$file" == helpers/* ]] || [[ "$file" == lib/* ]]; then
        echo "patterns/reusable" >> "$UPDATE_QUEUE_FILE"
    fi

    # 检查是否是配置变更
    if [[ "$file" == config/* ]] || [[ "$file" == *.config.* ]]; then
        echo "context/environment" >> "$UPDATE_QUEUE_FILE"
    fi

    # 检查是否是依赖变更
    if [[ "$file" == package.json ]] || [[ "$file" == requirements.txt ]] || [[ "$file" == Cargo.toml ]]; then
        echo "context/dependencies" >> "$UPDATE_QUEUE_FILE"
    fi
done

# 去重并排序
if [ -s "$UPDATE_QUEUE_FILE" ]; then
    SORTED_QUEUE=$(sort -u "$UPDATE_QUEUE_FILE")

    # 输出提示信息
    echo ""
    echo -e "${YELLOW}╔════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${YELLOW}║${NC} ${GREEN}Projector: 检测到以下模块需要更新文档:${NC}                  ${YELLOW}║${NC}"
    echo -e "${YELLOW}╠════════════════════════════════════════════════════════════╣${NC}"

    while IFS= read -r module; do
        printf "${YELLOW}║${NC}   - %-54s${YELLOW}║${NC}\n" "$module"
    done <<< "$SORTED_QUEUE"

    echo -e "${YELLOW}╠════════════════════════════════════════════════════════════╣${NC}"
    echo -e "${YELLOW}║${NC} ${GREEN}运行 /projector update 更新知识库${NC}                       ${YELLOW}║${NC}"
    echo -e "${YELLOW}╚════════════════════════════════════════════════════════════╝${NC}"
    echo ""
fi

# 清理临时文件
rm -f "$UPDATE_QUEUE_FILE"
