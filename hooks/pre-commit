#!/bin/bash
# pre-commit hook
# 在提交前检查是否需要更新知识库

set -e

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# 检查 PROJECTOR/ 目录是否存在
if [ ! -d "PROJECTOR" ]; then
    exit 0
fi

# 获取暂存区的文件
STAGED_FILES=$(git diff --cached --name-only 2>/dev/null || true)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

# 检查是否有源代码变更
HAS_SOURCE_CHANGES=false
for file in $STAGED_FILES; do
    # 跳过 PROJECTOR/ 目录本身的变更
    if [[ "$file" == PROJECTOR/* ]]; then
        continue
    fi

    # 跳过配置文件和文档
    if [[ "$file" == *.md ]] || [[ "$file" == *.txt ]] || [[ "$file" == .gitignore ]]; then
        continue
    fi

    # 检查是否是源代码文件
    if [[ "$file" == *.ts ]] || [[ "$file" == *.tsx ]] || [[ "$file" == *.js ]] || [[ "$file" == *.jsx ]] || \
       [[ "$file" == *.py ]] || [[ "$file" == *.rs ]] || [[ "$file" == *.go ]] || \
       [[ "$file" == *.java ]] || [[ "$file" == *.kt ]] || [[ "$file" == *.swift ]]; then
        HAS_SOURCE_CHANGES=true
        break
    fi
done

# 如果有源代码变更，检查 PROJECTOR/ 是否也有变更
if [ "$HAS_SOURCE_CHANGES" = true ]; then
    PROJECTOR_CHANGES=$(git diff --cached --name-only | grep "^PROJECTOR/" 2>/dev/null || true)

    if [ -z "$PROJECTOR_CHANGES" ]; then
        echo ""
        echo -e "${YELLOW}╔════════════════════════════════════════════════════════════╗${NC}"
        echo -e "${YELLOW}║${NC} ${RED}警告: 检测到源代码变更，但 PROJECTOR/ 未更新${NC}            ${YELLOW}║${NC}"
        echo -e "${YELLOW}╠════════════════════════════════════════════════════════════╣${NC}"
        echo -e "${YELLOW}║${NC} ${GREEN}建议先运行 /projector update 更新知识库${NC}                 ${YELLOW}║${NC}"
        echo -e "${YELLOW}║${NC}                                                          ${YELLOW}║${NC}"
        echo -e "${YELLOW}║${NC} ${GREEN}或者使用 --no-verify 跳过此检查${NC}                          ${YELLOW}║${NC}"
        echo -e "${YELLOW}╚════════════════════════════════════════════════════════════╝${NC}"
        echo ""

        # 询问用户是否继续
        read -p "是否继续提交? (y/N) " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            echo -e "${RED}提交已取消${NC}"
            exit 1
        fi
    fi
fi

exit 0
